# CI Pinned Versions — PROD (source de vérité)
#
# Ces versions sont utilisées par les jobs CI en mode PROD (workflow_call depuis build.yml).
# En QUALIF (push/PR), le CI utilise @latest pour détecter les incompatibilités tôt.
#
# Mise à jour après chaque QUALIF validée :
#   1. Vérifier les versions résolues dans les logs QUALIF (go install ... step)
#   2. Mettre à jour les variables ci-dessous
#   3. Committer : git commit -m "chore(ci): bump PROD pins après QUALIF vX.Y.Z"
#   4. Le prochain tag vX.Y.Z+1 utilisera automatiquement les nouvelles versions
#
# Versions actuellement pinnées (validées en QUALIF v1.7.0) :
PROTOC_GEN_GO_PIN=v1.35.1
PROTOC_GEN_GO_GRPC_PIN=v1.5.1
#
# Outils validés localement QUALIF v1.7.0 (informatif — versions CI dans build.yml/ci.yml) :
# GO_VERSION=1.24.2       (CI : 1.24)
# WAILS_VERSION=v2.12.0   (CI : v2.12.0 — identique)
# NODE_VERSION=25.7.0     (CI : 18 — build frontend OK dans les deux cas)
GO_PIN=1.24.2
WAILS_PIN=2.12.0
NPM_PIN=11.10.1
